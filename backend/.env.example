# QLib Web Management - Environment Variables
# Copy this file to .env and update values for your deployment

# ======== Database ========
# SQLite (default for development):
DATABASE_URL=sqlite:///./test.db
# MySQL (production):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/qlib_management
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/qlib_management

# ======== Security ========
# IMPORTANT: Change this to a strong random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ======== Training ========
# Training mode: "local" for local execution, "remote" for distributed
TRAINING_MODE=local

# QLib data directory
QLIB_PROVIDER_URI=~/.qlib/qlib_data/cn_data

# Remote training server (only needed if TRAINING_MODE=remote)
# TRAINING_SERVER_URL=http://training-server:8000
# TRAINING_SERVER_TIMEOUT=3600
# TRAINING_SERVER_USERNAME=
# TRAINING_SERVER_PASSWORD=

# Maximum concurrent training workers
MAX_TRAINING_WORKERS=2
# Worker database polling interval in seconds
WORKER_POLL_INTERVAL=5

# ======== CORS ========
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ======== Email (optional) ========
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=True
# SENDER_EMAIL=noreply@example.com
# VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
